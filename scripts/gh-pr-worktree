#!/usr/bin/env bash

set -e

# gh-pr-worktree: Check out a PR in a git worktree and open in Neovim
# Usage: gh-pr-worktree <PR_NUMBER> [REPO_PATH]

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

print_info() {
    echo -e "${BLUE}ℹ${NC} $1"
}

print_success() {
    echo -e "${GREEN}✓${NC} $1"
}

print_error() {
    echo -e "${RED}✗${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}⚠${NC} $1"
}

# Check if PR number is provided
if [ -z "$1" ]; then
    print_error "Usage: gh-pr-worktree <PR_NUMBER> [REPO_PATH]"
    exit 1
fi

PR_NUMBER="$1"
REPO_PATH="${2:-.}"

# Change to repo directory
cd "$REPO_PATH" || {
    print_error "Failed to change to directory: $REPO_PATH"
    exit 1
}

# Check if we're in a git repo
if ! git rev-parse --git-dir > /dev/null 2>&1; then
    print_error "Not in a git repository"
    exit 1
fi

# Get repo name
REPO_NAME=$(gh repo view --json nameWithOwner -q .nameWithOwner 2>/dev/null || basename "$(git rev-parse --show-toplevel)")

print_info "Fetching PR #${PR_NUMBER} from ${REPO_NAME}..."

# Fetch PR information
PR_INFO=$(gh pr view "$PR_NUMBER" --json number,headRefName,headRepository,headRepositoryOwner,title,state 2>/dev/null)

if [ -z "$PR_INFO" ]; then
    print_error "Failed to fetch PR #${PR_NUMBER}"
    print_info "Make sure you're in the correct repository and the PR exists"
    exit 1
fi

# Extract PR details
BRANCH_NAME=$(echo "$PR_INFO" | jq -r .headRefName)
PR_TITLE=$(echo "$PR_INFO" | jq -r .title)
PR_STATE=$(echo "$PR_INFO" | jq -r .state)
HEAD_REPO_OWNER=$(echo "$PR_INFO" | jq -r .headRepositoryOwner.login)

print_info "PR #${PR_NUMBER}: ${PR_TITLE}"
print_info "Branch: ${BRANCH_NAME}"
print_info "State: ${PR_STATE}"

# Determine worktree location based on repo structure
REPO_ROOT=$(git rev-parse --show-toplevel)
REPO_BASENAME=$(basename "$REPO_ROOT")

# Check if repo has a worktrees directory (like EMSmart2.0)
if [ -d "${REPO_ROOT}/worktrees" ]; then
    WORKTREE_DIR="${REPO_ROOT}/worktrees/pr-${PR_NUMBER}"
    print_info "Using existing worktrees/ directory structure"
# Check if worktrees are directly in repo directory (like BR)
# This checks if there are existing worktrees in the repo directory
elif git worktree list | grep -q "${REPO_ROOT}/" && [ $(git worktree list | wc -l) -gt 1 ]; then
    WORKTREE_DIR="${REPO_ROOT}/pr-${PR_NUMBER}"
    print_info "Using in-repo worktree structure"
else
    # Default: use .pr-worktrees in home directory
    WORKTREE_BASE="${HOME}/.pr-worktrees"
    WORKTREE_DIR="${WORKTREE_BASE}/${REPO_BASENAME}/pr-${PR_NUMBER}"
    mkdir -p "$(dirname "$WORKTREE_DIR")"
    print_info "Using default worktree location"
fi

# Check if worktree already exists
if [ -d "$WORKTREE_DIR" ]; then
    print_warning "Worktree already exists at: ${WORKTREE_DIR}"
    read -p "Do you want to remove and recreate it? (y/N): " -n 1 -r
    echo
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        print_info "Removing existing worktree..."
        git worktree remove --force "$WORKTREE_DIR" 2>/dev/null || rm -rf "$WORKTREE_DIR"
    else
        print_info "Opening existing worktree in Neovim..."
        cd "$WORKTREE_DIR" || exit 1
        nvim -c "Octo pr edit $PR_NUMBER" 2>/dev/null || nvim
        exit 0
    fi
fi

# Fetch the PR ref and create worktree directly
print_info "Fetching PR ref..."

# Get the PR head ref (format: refs/pull/NUMBER/head)
PR_REF="refs/pull/${PR_NUMBER}/head"

# Fetch the PR ref from GitHub
git fetch origin "${PR_REF}" 2>/dev/null || {
    print_error "Failed to fetch PR #${PR_NUMBER}"
    exit 1
}

# Get the commit SHA from FETCH_HEAD
PR_SHA=$(git rev-parse FETCH_HEAD)

# Clean up the branch if it already exists (from a previous worktree)
BRANCH_NAME="pr-${PR_NUMBER}"
if git show-ref --verify --quiet "refs/heads/${BRANCH_NAME}"; then
    print_info "Removing existing branch: ${BRANCH_NAME}..."
    git branch -D "${BRANCH_NAME}" 2>/dev/null
fi

# Create worktree with a proper branch (not detached HEAD)
print_info "Creating worktree at: ${WORKTREE_DIR}..."
git worktree add -b "${BRANCH_NAME}" "$WORKTREE_DIR" "$PR_SHA" 2>/dev/null || {
    print_error "Failed to create worktree"
    exit 1
}

# Set up branch tracking so gh pr view and Octo.nvim can detect the PR
git -C "$WORKTREE_DIR" config "branch.pr-${PR_NUMBER}.merge" "refs/pull/${PR_NUMBER}/head"
git -C "$WORKTREE_DIR" config "branch.pr-${PR_NUMBER}.remote" "origin"

print_success "Worktree created successfully with branch: pr-${PR_NUMBER}"

# Create a cleanup script in the worktree
cat > "${WORKTREE_DIR}/.cleanup-worktree.sh" << 'EOF'
#!/usr/bin/env bash
WORKTREE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
echo "Cleaning up worktree: ${WORKTREE_DIR}"
cd ..
git worktree remove --force "$WORKTREE_DIR"
echo "Worktree removed"
EOF

chmod +x "${WORKTREE_DIR}/.cleanup-worktree.sh"

# Change to worktree directory
cd "$WORKTREE_DIR" || exit 1

print_success "Switched to worktree: ${WORKTREE_DIR}"
print_info "Opening Neovim..."
echo ""
print_info "When done reviewing, you can clean up this worktree by running:"
echo -e "  ${GREEN}./.cleanup-worktree.sh${NC}"
echo ""

# Open Neovim
if command -v nvim > /dev/null 2>&1; then
    echo ""
    print_info "To start reviewing with Octo, run in Neovim:"
    echo -e "  ${GREEN}:Octo pr edit ${PR_NUMBER}${NC}"
    echo -e "  ${GREEN}:Octo review start${NC}"
    echo ""
    nvim
else
    print_error "Neovim not found"
    exit 1
fi

# After Neovim exits, ask if user wants to clean up
echo ""
read -p "Do you want to remove this worktree? (y/N): " -n 1 -r
echo
if [[ $REPLY =~ ^[Yy]$ ]]; then
    cd ..
    git worktree remove --force "$WORKTREE_DIR"
    print_success "Worktree removed"
else
    print_info "Worktree kept at: ${WORKTREE_DIR}"
    print_info "To remove it later, run: ./.cleanup-worktree.sh"
fi
